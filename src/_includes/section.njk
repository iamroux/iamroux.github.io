---
layout: base.njk
---
<h1>{{ title }}</h1>
{% set found = false %}
<ul class="post-list">
  {% for post in collections.writing %}
    {% if post.data.section == sectionName %}
    {% set found = true %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
  </li>
    {% endif %}
  {% endfor %}
</ul>
