---
layout: base.njk
---
<article>
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    <span class="section-label">{{ section }}</span>
  </header>
  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
