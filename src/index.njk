---
layout: base.njk
---
<div class="intro">
  <p>I write sometimes — about things I build, things I think about, things I notice. This is where it goes.</p>
</div>

<ul class="post-list">
  {% for post in collections.writing | batch(10) | first %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <span class="post-meta">
      <span class="section-label">{{ post.data.section }}</span>
      <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    </span>
  </li>
  {% endfor %}
</ul>
